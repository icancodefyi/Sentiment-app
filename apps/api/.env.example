# Copy to apps/api/.env (never commit .env)
GROQ_API_KEY=
# Optional — see https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile
# Optional — leave unset to run without persisting to MongoDB
# MONGODB_URI=mongodb://127.0.0.1:27017
# MONGODB_DB=sentilx
# (lowercase also works: mongodb_uri, mongodb_db)
#
# Email reports (5.11) — optional; PDF works without this
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# REPORT_EMAIL_FROM=
# REPORT_EMAIL_TO=
# SMTP_USE_TLS=1
